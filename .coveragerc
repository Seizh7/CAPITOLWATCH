# Coverage configuration
#
# Scope: analysis modules only (data_loader, feature_engineering,
#        preprocessing, evaluation, clustering algorithms).
# Excluded: run_* scripts (entry points, not unit-testable),
#           visualization/plotting, web (Streamlit), datapipeline (scraping).

[run]
source = capitolwatch

omit =
    # Entry-point scripts — not unit-testable
    capitolwatch/analysis/run_*.py
    capitolwatch/analysis/run_cluster_analysis.py
    capitolwatch/analysis/run_evaluation.py
    capitolwatch/analysis/run_visualization.py
    capitolwatch/analysis/clustering/run_*.py
    capitolwatch/analysis/cli.py
    capitolwatch/analysis/__main__.py
    # Plotting library — no logic to test
    capitolwatch/analysis/visualization.py
    capitolwatch/analysis/cluster_analysis.py
    # Feature store — IO wrapper, not logic
    capitolwatch/analysis/feature_store.py
    # Web/Streamlit — requires browser session
    capitolwatch/web/*
    # Data pipeline — scraping/enrichment
    capitolwatch/datapipeline/*
    # Services — covered indirectly via integration tests
    capitolwatch/services/*

[report]
fail_under = 70
show_missing = True
