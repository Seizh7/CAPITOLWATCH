# Git and CI
.git/
.github/
.gitignore

# Secrets — must never enter the image
.env
.env.*

# Documentation and project management files
.docs/
README.md
LICENCE

# Tests (not executed inside the container)
tests/

# Temporary / local outputs
*.log
