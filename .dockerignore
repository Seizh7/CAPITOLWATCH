# Python
.venv/
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Data — provided at runtime via Docker volumes
data/

# Development tooling and IDE config
.idea/
.vscode/
.DS_Store
